generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum SkuStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID_CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethodType {
  WECHAT
  ALIPAY
}

enum AdminRole {
  OWNER
  STAFF
}

enum AdminStatus {
  ACTIVE
  DISABLED
}

enum CustomerStatus {
  ACTIVE
  DISABLED
}

enum AuditAction {
  ADMIN_LOGIN
  ADMIN_USER_CREATED
  ADMIN_USER_UPDATED
  ADMIN_PASSWORD_RESET
  ORDER_STATUS_UPDATED
  ORDER_SHIPPING_UPDATED
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProductStatus @default(ACTIVE)
  skus        Sku[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("products")
}

model Sku {
  id                 String      @id @default(cuid())
  productId          String
  product            Product     @relation(fields: [productId], references: [id])
  name               String
  spec               String
  priceCents         Int
  originalPriceCents Int?
  stock              Int         @default(0)
  imageUrl           String?
  status             SkuStatus   @default(ACTIVE)
  orderItems         OrderItem[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([productId])
  @@map("skus")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address   String
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@map("customers")
}

model CustomerAccount {
  id                     String            @id @default(cuid())
  name                   String
  phone                  String            @unique
  passwordHash           String
  status                 CustomerStatus    @default(ACTIVE)
  failedLoginAttempts    Int               @default(0)
  lockedUntil            DateTime?
  lastLoginAt            DateTime?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  orders                 Order[]
  addresses              CustomerAddress[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@map("customer_accounts")
}

model CustomerAddress {
  id           String          @id @default(cuid())
  userId       String
  user         CustomerAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
  receiverName String
  phone        String
  address      String
  isDefault    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId])
  @@map("customer_addresses")
}

model Order {
  id               String             @id @default(cuid())
  orderNo          String             @unique
  customerId       String
  customer         Customer           @relation(fields: [customerId], references: [id])
  userId           String?
  user             CustomerAccount?   @relation(fields: [userId], references: [id])
  status           OrderStatus        @default(PENDING_PAYMENT)
  totalAmountCents Int
  paymentMethod    PaymentMethodType?
  shippingCarrier  String?
  trackingNo       String?
  remark           String?
  items            OrderItem[]
  statusLogs       OrderStatusLog[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  order           Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId           String
  sku             Sku    @relation(fields: [skuId], references: [id])
  skuNameSnapshot String
  unitPriceCents  Int
  quantity        Int
  subtotalCents   Int

  @@index([orderId])
  @@index([skuId])
  @@map("order_items")
}

model PaymentMethod {
  id           String            @id @default(cuid())
  type         PaymentMethodType
  name         String
  qrCodeUrl    String
  instructions String
  enabled      Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([enabled])
  @@map("payment_methods")
}

model AdminUser {
  id                  String           @id @default(cuid())
  email               String           @unique
  passwordHash        String
  displayName         String
  role                AdminRole        @default(OWNER)
  status              AdminStatus      @default(ACTIVE)
  mustChangePassword  Boolean          @default(false)
  failedLoginAttempts Int              @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  statusLogs          OrderStatusLog[]
  auditLogs           AuditLog[]       @relation("AdminAuditLogs")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("admin_users")
}

model AuditLog {
  id           String      @id @default(cuid())
  action       AuditAction
  actorAdminId String?
  actorAdmin   AdminUser?  @relation("AdminAuditLogs", fields: [actorAdminId], references: [id])
  targetType   String
  targetId     String?
  metadataJson String?
  createdAt    DateTime    @default(now())

  @@index([action])
  @@index([actorAdminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model OrderStatusLog {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  operatorId String?
  operator   AdminUser?   @relation(fields: [operatorId], references: [id])
  note       String?
  createdAt  DateTime     @default(now())

  @@index([orderId])
  @@index([operatorId])
  @@map("order_status_logs")
}
